{
  "expo": {
    "name": "Prayer Point",
    "slug": "prayer-point",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "prayerpoint",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FBF7F0"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.prayerpoint.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Prayer Point uses your microphone to record voice reflections that you can save to your private journal.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.prayerpoint.app",
      "versionCode": 1,
      "permissions": ["RECORD_AUDIO", "POST_NOTIFICATIONS"]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-video",
      [
        "expo-notifications",
        {
          "color": "#D4A843",
          "defaultChannel": "prayer-reminders"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
